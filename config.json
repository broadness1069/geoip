{
  "input": [
    {
      "type": "v2rayGeoIPDat",
      "action": "add",
      "args": {
        "uri": "https://github.com/Loyalsoldier/geoip/releases/latest/download/geoip.dat"
      }
    },
    {
      "type": "text",
      "action": "add",
      "args": {
        "name": "bloomberg",
        "uri": "custom_tags/bloomberg.txt"
      }
    }
  ],
  "output": [
    {
      "type": "v2rayGeoIPDat",
      "action": "output",
      "args": {
        "outputDir": "./output",
        "outputName": "geoip.dat"
      }
    },
    {
      "type": "maxmindMMDB",
      "action": "output",
      "args": {
        "outputDir": "./output",
        "outputName": "Country.mmdb"
      }
    },
    {
      "type": "singboxSRS",
      "action": "output",
      "args": {
        "outputDir": "./output",
        "outputName": "geoip.srs"
      }
    },
    {
      "type": "mihomoMRS",
      "action": "output",
      "args": {
        "outputDir": "./output",
        "outputName": "geoip.mrs"
      }
    },
    {
      "type": "singboxSRS",
      "action": "output",
      "args": {
        "outputDir": "./output/srs"
      }
    },
    {
      "type": "mihomoMRS",
      "action": "output",
      "args": {
        "outputDir": "./output/mrs"
      }
    },
    {
      "type": "nginx",
      "action": "output",
      "args": {
        "outputDir": "./output/nginx"
      }
    }
  ]
}